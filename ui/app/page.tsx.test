"use client";

import { invoke } from "@tauri-apps/api/core";
import { useState } from "react";

export default function Home() {
  const [version, setVersion] = useState("");

  async function test() {
    const v = await invoke<string>("get_version");
    setVersion(v);
  }

  return (
    <main>
      <button onClick={test}>
        Test Tauri
      </button>

      <p>{version}</p>
    </main>
  );
}